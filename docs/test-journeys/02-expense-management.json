    {
      "id": "EXP-01",
      "destructive": true,
      "name": "Create shared expense (equal split)",
      "tags": ["crud", "create"],
      "steps": [
        {
          "action": "navigate",
          "url": "/family-ledger-web/expense/new"
        },
        {
          "action": "fill",
          "selector": "input[type=\"date\"]",
          "value": "2026-04-04"
        },
        {
          "action": "fill",
          "selector": "input[placeholder*=\"晚餐\"], input[placeholder*=\"描述\"], input[placeholder*=\"說明\"], input[placeholder*=\"名稱\"]",
          "value": "測試晚餐"
        },
        {
          "action": "fill",
          "selector": "input[type=\"number\"]",
          "value": "600"
        },
        {
          "action": "selectOption",
          "selector": "select:first-of-type",
          "value": { "index": 0 }
        },
        {
          "action": "click",
          "selector": "button:has-text(\"共同支出\")"
        },
        {
          "action": "click",
          "selector": "button:has-text(\"均分\")"
        },
        {
          "action": "click",
          "selector": "button:has-text(\"新增支出\")"
        },
        {
          "action": "waitForNavigation"
        },
        {
          "action": "assertUrl",
          "not": true,
          "contains": "/expense/new"
        },
        {
          "action": "screenshot",
          "name": "EXP-01-shared-expense-created"
        }
      ]
    },
