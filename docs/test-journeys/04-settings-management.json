          "action": "navigate",
          "url": "/family-ledger-web/settings"
        },
        {
          "action": "click",
          "selector": "li:has-text('測試成員') button[aria-label*='刪除'], li:has-text('測試成員') button[title*='刪除'], li:has-text('測試成員') button:has-text('🗑'), li:has-text('測試成員') [data-testid*='delete']"
        },
        {
          "action": "click",
          "selector": "button:has-text('確認'), button:has-text('刪除'), button:has-text('確定')"
        },
        {
          "action": "wait",
          "ms": 1000
        },
        {
          "action": "screenshot",
          "name": "SET-04-delete-member"
        }
      ],
      "tags": ["crud", "members"]
    },
    {
      "id": "SET-05",
      "name": "View invite code",
