{
  "journey": "settings-management",
  "version": "1.0.0",
  "baseUrl": "https://mac-mini.tailde842d.ts.net",
  "execution": {
    "mode": "sequential",
    "order": 4,
    "requiresAuth": true
  },
  "credentials": {
    "USER": {
      "email": "test-user@example.com",
      "password": "Test1234!",
      "role": "USER"
    }
  },
  "testCases": [
    {
      "id": "SET-01",
      "name": "Settings page renders",
      "role": "USER",
      "steps": [
        {
          "action": "navigate",
          "url": "/family-ledger-web/settings"
        },
        {
          "action": "assertVisible",
          "text": "設定"
        },
        {
          "action": "screenshot",
          "name": "SET-01-settings-page"
        }
      ],
      "tags": ["smoke"]
    },
    {
      "id": "SET-02",
      "destructive": true,
      "name": "Add member",
      "role": "USER",
      "steps": [
        {
          "action": "navigate",
          "url": "/family-ledger-web/settings"
        },
        {
          "action": "fill",
          "selector": "input[placeholder='輸入成員姓名']",
          "value": "測試成員"
        },
        {
          "action": "click",
          "selector": "button:has-text('新增')"
        },
        {
          "action": "wait",
          "ms": 1000
        },
        {
          "action": "assertVisible",
          "text": "測試成員"
        },
        {
          "action": "screenshot",
          "name": "SET-02-add-member"
        }
      ],
      "tags": ["crud", "members"]
    },
    {
      "id": "SET-03",
      "destructive": true,
      "name": "Edit member name",
      "role": "USER",
      "steps": [
        {
          "action": "navigate",
          "url": "/family-ledger-web/settings"
        },
        {
          "action": "click",
          "selector": "li:has-text('測試成員') button[aria-label*='編輯'], li:has-text('測試成員') button[title*='編輯'], li:has-text('測試成員') button:has-text('✏'), li:has-text('測試成員') [data-testid*='edit']"
        },
        {
          "action": "fill",
          "selector": "input[value='測試成員'], input[placeholder='輸入成員姓名']",
          "value": "測試成員已編輯"
        },
        {
          "action": "click",
          "selector": "button:has-text('儲存'), button:has-text('確認'), button[type='submit']"
        },
        {
          "action": "wait",
          "ms": 1000
        },
        {
          "action": "screenshot",
          "name": "SET-03-edit-member"
        }
      ],
      "tags": ["crud", "members"]
    },
    {
      "id": "SET-04",
      "destructive": true,
      "name": "Delete member",
      "role": "USER",
