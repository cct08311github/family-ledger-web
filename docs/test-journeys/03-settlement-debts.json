      "id": "STL-04",
      "name": "Open settlement dialog",
      "role": "USER",
      "steps": [
        {
          "action": "navigate",
          "url": "/family-ledger-web/split"
        },
        {
          "action": "click",
          "selector": "button:has-text('記錄轉帳')"
        },
        {
          "action": "waitForSelector",
          "selector": "[role='dialog'], [data-testid='settlement-dialog'], .dialog, .modal"
        },
        {
          "action": "assertVisible",
          "text": "確認"
        },
        {
          "action": "screenshot",
          "name": "STL-04-settlement-dialog-open"
        }
      ],
      "tags": ["crud"]
    },
    {
      "id": "STL-05",
      "name": "Create settlement",
      "role": "USER",
      "steps": [
        {
          "action": "navigate",
          "url": "/family-ledger-web/split"
        },
        {
          "action": "click",
          "selector": "button:has-text('記錄轉帳')"
        },
        {
          "action": "waitForSelector",
          "selector": "[role='dialog'], [data-testid='settlement-dialog'], .dialog, .modal"
        },
        {
          "action": "fill",
          "selector": "input[type='date']",
          "value": "2026-04-04"
        },
        {
          "action": "selectOption",
          "selector": "select:nth-of-type(1)",
          "index": 1
        },
        {
          "action": "selectOption",
          "selector": "select:nth-of-type(2)",
          "index": 2
        },
        {
          "action": "fill",
          "selector": "input[type='number']",
          "value": "500"
        },
        {
          "action": "fill",
          "selector": "input[type='text']",
          "value": "測試結算"
        },
        {
          "action": "click",
          "selector": "button:has-text('確認')"
        },
        {
          "action": "wait",
          "ms": 2000
        },
        {
          "action": "screenshot",
          "name": "STL-05-settlement-created"
        }
      ],
      "tags": ["crud"]
    },
    {
