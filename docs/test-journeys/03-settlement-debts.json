    {
      "id": "STL-07",
      "name": "Delete settlement",
      "role": "USER",
      "steps": [
        {
          "action": "navigate",
          "url": "/family-ledger-web/split"
        },
        {
          "action": "click",
          "selector": "[data-testid='settlement-item'] button[aria-label*='刪除'], [data-testid='settlement-item'] button:has-text('刪除'), .settlement-item button[aria-label*='delete'], .settlement-item button:last-child"
        },
        {
          "action": "waitForSelector",
          "selector": "[role='dialog'] button:has-text('確認'), [role='alertdialog'] button:has-text('確認'), button:has-text('確定刪除')"
        },
        {
          "action": "click",
          "selector": "[role='dialog'] button:has-text('確認'), [role='alertdialog'] button:has-text('確認'), button:has-text('確定刪除')"
        },
        {
          "action": "wait",
          "ms": 1000
        },
        {
          "action": "screenshot",
          "name": "STL-07-settlement-deleted"
        }
      ],
      "tags": ["crud"]
